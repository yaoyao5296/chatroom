{
  "name": "chatroom",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "start": "NODE_ENV=production node --env-file=.env --import tsx api/server.ts",
    "start:lean": "NODE_ENV=production node --env-file=.env --max-old-space-size=384 --optimize-for-size --max-semi-space-size=2 --initial-old-space-size=128 --import tsx api/server.ts",
    "start:budget": "NODE_ENV=production node --env-file=.env --max-old-space-size=128 --optimize-for-size --max-semi-space-size=1 --initial-old-space-size=64 --import tsx api/server.ts",
    "start:win": "set NODE_ENV=production && node --env-file=.env --max-old-space-size=128 --optimize-for-size --max-semi-space-size=1 --initial-old-space-size=64 --import tsx api/server.ts",
    "client:dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "check": "tsc --noEmit",
    "server:dev": "nodemon",
    "dev": "concurrently \"npm run client:dev\" \"npm run server:dev\"",
    "android:build": "vite build && cap sync android && cd android && gradlew assembleDebug && cd ..",
    "android:open": "cap open android",
    "android:run": "cap run android",
    "android:sync": "cap sync android",
    "ios:add": "cap add ios",
    "ios:build": "vite build && cap sync ios",
    "ios:open": "cap open ios",
    "electron:dev": "vite build && electron .",
    "electron:build:win": "vite build && electron-builder --win",
    "electron:build:mac": "vite build && electron-builder --mac",
    "electron:build:linux": "vite build && electron-builder --linux",
    "electron:build:all": "vite build && electron-builder --win --mac --linux"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  },
  "dependencies": {
    "@capacitor/app": "^8.1.0",
    "@capacitor/camera": "^8.2.0",
    "@capacitor/cli": "^8.4.0",
    "@capacitor/core": "^8.4.0",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/local-notifications": "^7.0.0",
    "@sentry/react": "^10.63.0",
    "@vladmandic/face-api": "^1.7.15",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.10.0",
    "cloudinary": "^2.10.0",
    "clsx": "^2.1.1",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "ioredis": "^5.5.0",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.511.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^8.0.11",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.3.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^3.0.2",
    "tsx": "^4.20.3",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@capacitor/android": "^8.4.0",
    "@capacitor/ios": "^8.4.0",
    "@eslint/js": "^9.25.0",
    "@types/bcryptjs": "^3.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.15.30",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/socket.io": "^3.0.2",
    "@vercel/node": "^5.3.6",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "eslint": "^9.25.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "nodemon": "^3.1.10",
    "postcss": "^8.5.3",
    "sharp": "^0.35.3",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.30.1",
    "vite": "^6.4.3",
    "vite-plugin-trae-solo-badge": "^1.0.0",
    "vite-tsconfig-paths": "^5.1.4"
  },
  "build": {
    "appId": "com.chatroom.desktop",
    "productName": "ChatRoom",
    "directories": {
      "output": "release"
    },
    "npmRebuild": true,
    "asarUnpack": [
      "**/*.node",
      "node_modules/better-sqlite3/**/*"
    ],
    "files": [
      "dist/**/*",
      "api/**/*",
      "electron/**/*",
      "node_modules/**/*",
      "package.json",
      ".env"
    ],
    "extraResources": [
      { "from": "uploads", "to": "uploads" }
    ],
    "win": {
      "target": "nsis",
      "icon": "public/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.social-networking"
    },
    "linux": {
      "target": "AppImage",
      "category": "Network"
    }
  }
}
